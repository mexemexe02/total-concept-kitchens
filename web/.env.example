# =============================================================================
# BUSINESS CONTACT (copy from Facebook Page → About while logged in)
# Meta blocks bots; these values cannot be scraped automatically.
# Copy this file to `.env.local` and fill in. Restart `npm run dev` after edits.
# =============================================================================

# From Facebook Page (see content/META_PROFILE_SNAPSHOT.md)
NEXT_PUBLIC_TCK_PHONE_DISPLAY=(705) 309-4443
NEXT_PUBLIC_TCK_PHONE_TEL=+17053094443
NEXT_PUBLIC_TCK_EMAIL=totalconceptkitchens@gmail.com

# Defaults match Instagram @totalconceptkitchens (override for launch)
NEXT_PUBLIC_TCK_CITY=Barrie
NEXT_PUBLIC_TCK_REGION=Ontario
NEXT_PUBLIC_TCK_STREET_ADDRESS=438 Dunlop St W
NEXT_PUBLIC_TCK_POSTAL=L4N 1C2

# Optional: hours line (e.g. Mon–Fri 8am–5pm)
NEXT_PUBLIC_TCK_HOURS=

# Service area sentence for footer / trust strip
NEXT_PUBLIC_TCK_SERVICE_AREA=

# Optional: override default marketing tagline
NEXT_PUBLIC_TCK_TAGLINE=

NEXT_PUBLIC_TCK_OWNER_NAME=Ethan
NEXT_PUBLIC_TCK_OWNER_ROLE=Owner

# Production URL for Open Graph (https://yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3012

# false = hide “sample testimonial” notes and presentation footer line
NEXT_PUBLIC_TCK_PRESENTATION_MODE=true

# =============================================================================
# Instagram gallery API (server-only — no NEXT_PUBLIC_ prefix)
# =============================================================================
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=
REVALIDATE_SECRET=

# =============================================================================
# Biz portal (Ethan) — sign in at /portal
# =============================================================================
# Strong random string for signing the session cookie (e.g. openssl rand -hex 32)
TCK_PORTAL_SECRET=
# Portal login password (keep private; never commit .env.local)
TCK_PORTAL_PASSWORD=

# =============================================================================
# Pantry chatbot — optional smarter fallback when FAQ does not match
# =============================================================================
OPENAI_API_KEY=
# Optional model override (default gpt-4o-mini)
OPENAI_CHAT_MODEL=
# Optional: show backend source tag in widget (faq/openai/fallback) for debugging
NEXT_PUBLIC_CHAT_DEBUG=false
